---
import Layout from "../../layouts/Layout.astro";
import { getEntry, getCollection } from "astro:content";

const dateTimeFormat = new Intl.DateTimeFormat("nl-NL");
const pluralRules = new Intl.PluralRules("en-US");

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((product) => ({
    params: { id: product.id },
  }));
}

const { id } = Astro.params;
if (id === undefined) {
  throw new Error("No product ID provided");
}

const product = await getEntry("products", id.replace("%23", "#"));
if (product === undefined) {
  throw new Error(`Product with ID ${id} not found`);
}

const priceHistory = product.data.priceHistory.map((entry) => ({
  ...entry,
  start: new Date(entry.start),
  end: new Date(entry.end),
}));
const presenceRanges = product.data.presenceRanges.map((range) => ({
  ...range,
  start: new Date(range.start),
  end: new Date(range.end),
}));
const currentPresence = presenceRanges.at(-1)?.type;

function yesterday(date: string | Date) {
  const dateCopy = new Date(date);
  dateCopy.setDate(dateCopy.getDate() - 1);
  return dateCopy;
}

function countDays(range: { start: Date; end: Date }) {
  return Math.floor(
    (range.end.getTime() - range.start.getTime()) / (1000 * 60 * 60 * 24)
  );
}

function detectRecurringPattern(
  absenceRanges: Array<{ start: Date; end: Date | undefined }>
) {
  // Check for regular intervals between absences
  if (absenceRanges.length >= 3) {
    const intervals = [];
    for (let i = 1; i < absenceRanges.length; i++) {
      const prevStart = absenceRanges[i - 1].start;
      const currentStart = absenceRanges[i].start;
      const daysDiff = Math.ceil(
        (currentStart.getTime() - prevStart.getTime()) / (1000 * 60 * 60 * 24)
      );
      intervals.push(daysDiff);
    }

    const avgInterval = intervals.reduce((a, b) => a + b, 0) / intervals.length;
    const variance =
      intervals.reduce(
        (acc, interval) => acc + Math.pow(interval - avgInterval, 2),
        0
      ) / intervals.length;
    const stdDev = Math.sqrt(variance);

    // If standard deviation is less than 20% of the average, consider it regular
    if (stdDev < avgInterval * 0.2 && avgInterval > 30) {
      return {
        type: "regular",
        averageInterval: Math.round(avgInterval),
        consistency: Math.round((1 - stdDev / avgInterval) * 100),
      };
    }
  }

  return null;
}

const recurringPattern = detectRecurringPattern(
  presenceRanges.filter((r) => r.type === "absent")
);

function getBadgeTypeForType(
  type: "present" | "absent" | "soldOut"
): "success" | "danger" | "warning" {
  switch (type) {
    case "present":
      return "success";
    case "absent":
      return "danger";
    case "soldOut":
      return "warning";
  }
}

function getColorForType(type: "present" | "absent" | "soldOut"): string {
  switch (type) {
    case "present":
      return "--wa-color-green-50";
    case "absent":
      return "--wa-color-red-50";
    case "soldOut":
      return "--wa-color-yellow-50";
  }
}

function getLabelForType(type: "present" | "absent" | "soldOut"): string {
  switch (type) {
    case "present":
      return "In stock";
    case "absent":
      return "Not on the website";
    case "soldOut":
      return "Sold out";
  }
}

function atLeastTwo<Value>(values: Array<Value>): Array<Value> {
  if (values.length >= 2) {
    return values;
  } else if (values.length === 1) {
    return [values[0], values[0]];
  } else {
    throw new Error("No values provided");
  }
}
---

<script>
  import "@weblogin/trendchart-elements";
</script>

<Layout>
  <main>
    <wa-breadcrumb>
      <wa-breadcrumb-item href={import.meta.env.BASE_URL}>
        <wa-icon slot="start" name="house"></wa-icon>
        Home
      </wa-breadcrumb-item>
      <wa-breadcrumb-item>{id}</wa-breadcrumb-item>
    </wa-breadcrumb>

    <hgroup>
      <h1>{id}</h1>
      {
        currentPresence !== undefined && (
          <wa-tag variant={getBadgeTypeForType(currentPresence)}>
            {getLabelForType(currentPresence)}
          </wa-tag>
        )
      }
      <!-- if in stock, <HowMuchTimeLeft /> until out of stock again -->
    </hgroup>

    <wa-card>
      <h2 slot="header">
        <wa-icon name="boxes-stacked" variant="solid"></wa-icon>
        Availability
      </h2>
      <div class="wa-split">
        <date datetime={presenceRanges[0].start.toISOString()}
          >{dateTimeFormat.format(presenceRanges[0].start)}</date
        >
        <date
          datetime={yesterday(
            presenceRanges.at(-1)?.end ?? new Date()
          ).toISOString()}
          >{
            dateTimeFormat.format(
              yesterday(presenceRanges.at(-1)?.end ?? new Date())
            )
          }</date
        >
      </div>
      <tc-stack
        horizontal
        values={JSON.stringify(presenceRanges.map(countDays))}
        labels={JSON.stringify(
          presenceRanges.map(
            (r) =>
              `${getLabelForType(r.type)}: ${dateTimeFormat.formatRange(r.start, yesterday(r.end))} (${countDays(r)} ${pluralRules.select(countDays(r)) === "one" ? "day" : "days"})`
          )
        )}
        tooltip-format="@L"
        radius="20"
        gap="3"
        style={presenceRanges.map((r, i) => `--shape-color-${i + 1}: var(${getColorForType(r.type)});`).join(" ")}
      ></tc-stack>

      <p slot="footer">
        {
          recurringPattern ? (
            <span>
              This product tends to appear in stock every
              <strong> {recurringPattern.averageInterval} days</strong> on
              average
            </span>
          ) : (
            <span>
              This product has been out of stock
              <strong>
                {presenceRanges.filter((r) => r.type !== "present").length}{" "}
                {
                  { one: "time", other: "times" }[
                    pluralRules.select(
                      presenceRanges.filter((r) => r.type !== "present").length
                    ) as "one" | "other"
                  ]
                }
              </strong>{" "}
              since it first appeared.
            </span>
          )
        }
      </p>
    </wa-card>

    <wa-card>
      <h2 slot="header">
        <wa-icon name="boxes-stacked" variant="solid"></wa-icon>
        Price history
      </h2>
      <div class="wa-flank">
        <div class="wa-split:column">
          <span>
            €{Math.max(...priceHistory.map((entry) => entry.priceCents / 100))}
          </span>
          <span>
            €{Math.min(...priceHistory.map((entry) => entry.priceCents / 100))}
          </span>
        </div>
        <tc-line
          values={JSON.stringify(
            atLeastTwo(priceHistory.map((entry) => entry.priceCents / 100))
          )}
          labels={JSON.stringify(
            atLeastTwo(
              priceHistory.map((entry) =>
                dateTimeFormat.formatRange(entry.start, yesterday(entry.end))
              )
            )
          )}
          tooltip-format="€@V (@L)"
          min={Math.min(...priceHistory.map((entry) => entry.priceCents / 100))}
        ></tc-line>
      </div>
    </wa-card>
  </main>
</Layout>

<style>
  main {
    margin-block-start: var(--wa-space-2xl);
    padding-block-end: var(--wa-space-2xl);
    display: grid;
    gap: var(--wa-space-3xl);
  }

  wa-card h2 {
    margin-block: var(--wa-space-s);
  }

  tc-stack {
    width: 100%;
  }

  tc-line {
    width: 100%;
    height: 150px;
    margin-block: 0.5lh;
  }
</style>
